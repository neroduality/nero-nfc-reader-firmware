+/* Must match firmware `firmware/port/include/ccid_usb_desc.h`; CCID owns the
+ * primary USB endpoint slots and keeps interrupt/bulk endpoints on distinct
+ * endpoint numbers for better host-driver compatibility. */
+#define NERO_USB_CCID_EP_INT     0x81u
+#define NERO_USB_CCID_EP_OUT     0x03u
+#define NERO_USB_CCID_EP_IN      0x82u
+#define NERO_USB_CCID_BULK_EPSIZE 64u
+#define NERO_USB_CCID_INT_EPSIZE 8u
+
+/* CCID_DW_FEATURES_EXTENDED_APDU = 0x000404BA (Smart-Card_USB_CCID §4.2.6). */
+static const uint8_t kNeroUsbCc54[54] = {
+    54,  0x21, 0x10, 0x01, 0x00, 0x07, 0x02, 0x00, 0x00, 0x00, 0xC0, 0x12, 0x00, 0x00,
+    0xC0, 0x12, 0x00, 0x00, 0x00, 0x67, 0x32, 0x00, 0x00, 0x8F, 0x9D, 0x0C, 0x00, 0x00, 0xFE,
+    0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xBA, 0x04, 0x04, 0x00,
+    0x0C, 0x08, 0x00, 0x00, 0xFF, 0xFF, 0x00, 0x00, 0x00, 0x01};
+
+static size_t nero_usb_ccid_emit_interface_desc(uint8_t *dst, uint8_t interface_number,
+                                                uint8_t ccid_string_index) {
+  if (!dst) {
+    return (size_t)0;
+  }
+
+  uint8_t *p = dst;
+
+  *p++ = 9;
+  *p++ = TUSB_DESC_INTERFACE;
+  *p++ = interface_number;
+  *p++ = 0;
+  *p++ = 3;
+  *p++ = TUSB_CLASS_SMART_CARD;
+  *p++ = 0;
+  *p++ = 0;
+  *p++ = ccid_string_index;
+
+  memcpy(p, kNeroUsbCc54, sizeof(kNeroUsbCc54));
+  p += sizeof(kNeroUsbCc54);
+
+  *p++ = 7;
+  *p++ = TUSB_DESC_ENDPOINT;
+  *p++ = NERO_USB_CCID_EP_OUT;
+  *p++ = TUSB_XFER_BULK;
+  *p++ = (uint8_t)(NERO_USB_CCID_BULK_EPSIZE & 0xFFu);
+  *p++ = (uint8_t)((NERO_USB_CCID_BULK_EPSIZE >> 8) & 0xFFu);
+  *p++ = 0;
+
+  *p++ = 7;
+  *p++ = TUSB_DESC_ENDPOINT;
+  *p++ = NERO_USB_CCID_EP_IN;
+  *p++ = TUSB_XFER_BULK;
+  *p++ = (uint8_t)(NERO_USB_CCID_BULK_EPSIZE & 0xFFu);
+  *p++ = (uint8_t)((NERO_USB_CCID_BULK_EPSIZE >> 8) & 0xFFu);
+  *p++ = 0;
+
+  *p++ = 7;
+  *p++ = TUSB_DESC_ENDPOINT;
+  *p++ = NERO_USB_CCID_EP_INT;
+  *p++ = TUSB_XFER_INTERRUPT;
+  *p++ = (uint8_t)(NERO_USB_CCID_INT_EPSIZE & 0xFFu);
+  *p++ = (uint8_t)((NERO_USB_CCID_INT_EPSIZE >> 8) & 0xFFu);
+  *p++ = 50;
+
+  return static_cast<size_t>(p - dst);
+}
+#endif /* NERO_CCID_USB_BUILD */
 
