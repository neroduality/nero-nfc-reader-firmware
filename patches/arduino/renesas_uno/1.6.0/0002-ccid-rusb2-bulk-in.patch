+    rusb->BEMPENB |= TU_BIT(num);
+  }
 
   if (dir || (xfer != TUSB_XFER_BULK)) {
     *ctr = RUSB2_PIPE_CTR_PID_BUF;
@@ -894,6 +916,7 @@
