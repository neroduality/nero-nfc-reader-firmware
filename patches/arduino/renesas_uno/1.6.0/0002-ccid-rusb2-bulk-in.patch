+static void process_pipe_bemp(uint8_t rhport, unsigned num)
+{
+  rusb2_reg_t* rusb = RUSB2_REG(rhport);
+  pipe_state_t* pipe = &_dcd.pipe[num];
+
+  if (!pipe->ep || !tu_edpt_dir(pipe->ep) || (pipe->buf == NULL) || (pipe->remaining != 0)) {
+    return;
+  }
+
+  wait_pipe_fifo_empty(rusb, (uint8_t) num);
+  pipe->buf = NULL;
+  dcd_event_xfer_complete(rhport, pipe->ep, pipe->length, XFER_RESULT_SUCCESS, true);
+}
+
 static void process_pipe_brdy(uint8_t rhport, unsigned num)
 {
   rusb2_reg_t* rusb = RUSB2_REG(rhport);
@@ -579,6 +593,10 @@
   const unsigned dir  = tu_edpt_dir(pipe->ep);
   bool completed;
 
+  if (dir && (pipe->buf == NULL)) {
+    return;
+  }
+
   if (dir) {
     /* IN */
     completed = pipe_xfer_in(rusb, num);
@@ -863,6 +881,10 @@
